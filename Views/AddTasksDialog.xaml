<Window x:Class="CarWorkshopWPF.Views.AddTasksDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dodaj zadania naprawcze"
        Height="600" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#ECF0F1">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Dodaj usterki / zadania do tego zlecenia"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Typ usługi" FontSize="11" Margin="0,0,0,3"/>
                <ComboBox x:Name="ServiceCombo" Padding="5" SelectionChanged="ServiceCombo_SelectionChanged"/>
                <TextBlock Text="Dodatkowe informacje (opcjonalnie)" FontSize="11" Margin="0,8,0,3"/>
                <TextBox x:Name="ExtraInfoTextBox" Height="50" Padding="5" TextWrapping="Wrap" AcceptsReturn="True"/>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Cena (zł):" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="PriceTextBox" Width="120" Padding="5" Text="100"/>
                    <Button Content="➕ Dodaj zadanie do listy" Style="{StaticResource SuccessButton}"
                            Margin="15,0,0,0" Click="AddButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Dodane zadania:" FontWeight="Bold" Margin="0,0,0,8"/>
                <Button DockPanel.Dock="Bottom" Content="🗑 Usuń zaznaczone"
                        Style="{StaticResource DangerButton}" Width="180" HorizontalAlignment="Left"
                        Margin="0,8,0,0" Click="RemoveButton_Click"/>
                <ListBox x:Name="TasksList"/>
            </DockPanel>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Anuluj" Style="{StaticResource GreyButton}" Width="100" Click="CancelButton_Click" Margin="0,0,5,0"/>
            <Button Content="✓ Zatwierdź" Style="{StaticResource PrimaryButton}" Width="180" Click="OkButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
