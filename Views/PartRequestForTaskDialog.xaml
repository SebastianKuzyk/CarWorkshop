<Window x:Class="CarWorkshopWPF.Views.PartRequestForTaskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zgłoszenie do magazynu"
        Height="350" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#ECF0F1"
        ResizeMode="NoResize">
    <Border Margin="15" Background="White" CornerRadius="8" Padding="15">
        <StackPanel>
            <TextBlock Text="Zgłoszenie zapotrzebowania na część" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

            <TextBlock Text="Część:" FontWeight="Bold" Margin="0,5,0,3"/>
            <ComboBox x:Name="PartCombo" Padding="6"/>

            <TextBlock x:Name="CustomNameLabel" Text="Lub wpisz nazwę (jeśli brak w magazynie):" FontWeight="Bold" Margin="0,8,0,3"/>
            <TextBox x:Name="CustomNameTextBox" Padding="6"/>

            <TextBlock Text="Ilość:" FontWeight="Bold" Margin="0,8,0,3"/>
            <TextBox x:Name="QuantityTextBox" Padding="6" Text="1"/>

            <StackPanel Orientation="Horizontal" Margin="0,15,0,0" HorizontalAlignment="Right">
                <Button Content="Anuluj" Style="{StaticResource GreyButton}" Width="100" Click="CancelButton_Click" Margin="0,0,5,0"/>
                <Button Content="Wyślij zgłoszenie" Style="{StaticResource SuccessButton}" Width="160" Click="SendButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
