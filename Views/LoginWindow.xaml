<Window x:Class="CarWorkshopWPF.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Logowanie - Warsztat Samochodowy"
        Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#ECF0F1">
    <Grid>
        <Border Background="White" CornerRadius="10" Margin="30" Padding="30">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="2" Opacity="0.15"/>
            </Border.Effect>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="🔧 Warsztat Samochodowy"
                           FontSize="20" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="#2C3E50"
                           Margin="0,0,0,5"/>
                <TextBlock Text="Zaloguj się do systemu"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Foreground="#7F8C8D"
                           Margin="0,0,0,25"/>

                <TextBlock Text="Login" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="LoginTextBox"
                         Height="35"
                         Padding="8"
                         FontSize="14"
                         BorderBrush="#BDC3C7"
                         Margin="0,0,0,15"/>

                <TextBlock Text="Hasło" FontWeight="Bold" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox"
                             Height="35"
                             Padding="8"
                             FontSize="14"
                             BorderBrush="#BDC3C7"
                             Margin="0,0,0,20"/>

                <Button Content="Zaloguj"
                        Height="40"
                        Background="#3498DB"
                        Foreground="White"
                        FontSize="14"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="LoginButton_Click"/>

                <TextBlock x:Name="MessageLabel"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"
                           FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
