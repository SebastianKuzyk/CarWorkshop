<Window x:Class="CarWorkshopWPF.Views.UpdateProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edycja profilu"
        Height="450" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="#ECF0F1"
        ResizeMode="NoResize">
    <Border Margin="20" Background="White" CornerRadius="8" Padding="20">
        <StackPanel>
            <TextBlock Text="Aktualizacja profilu" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="#2C3E50"/>

            <TextBlock Text="Login" FontWeight="Bold" Margin="0,5,0,3"/>
            <TextBox x:Name="LoginTextBox" Padding="6"/>

            <TextBlock Text="Hasło (puste = bez zmiany)" FontWeight="Bold" Margin="0,8,0,3"/>
            <TextBox x:Name="PasswordTextBox" Padding="6"/>

            <TextBlock Text="Telefon" FontWeight="Bold" Margin="0,8,0,3"/>
            <TextBox x:Name="PhoneTextBox" Padding="6"/>

            <TextBlock Text="Email" FontWeight="Bold" Margin="0,8,0,3"/>
            <TextBox x:Name="EmailTextBox" Padding="6"/>

            <StackPanel Orientation="Horizontal" Margin="0,20,0,0" HorizontalAlignment="Right">
                <Button Content="Anuluj" Style="{StaticResource GreyButton}" Width="100" Click="CancelButton_Click" Margin="0,0,5,0"/>
                <Button Content="Zapisz" Style="{StaticResource SuccessButton}" Width="100" Click="SaveButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
