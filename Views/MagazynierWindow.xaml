<Window x:Class="CarWorkshopWPF.Views.MagazynierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panel Magazyniera - Warsztat Samochodowy"
        Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#ECF0F1">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#7B341E">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Background="#5D2E1B" Margin="0">
                    <TextBlock Text="📦 Magazynier" Foreground="White" FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,15,0,0"/>
                    <TextBlock x:Name="labelUser" Text="👤 -" Foreground="#BDC3C7" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,5,0,15"/>
                </StackPanel>

                <Button x:Name="buttonLogout" DockPanel.Dock="Bottom"
                        Content="🚪 Wyloguj" Style="{StaticResource NavButton}" Background="#C0392B"
                        Click="buttonLogout_Click"/>
                <Button x:Name="editProfileButton" DockPanel.Dock="Bottom"
                        Content="✏ Edytuj profil" Style="{StaticResource NavButton}" Background="#5D2E1B"
                        Click="editProfileButton_Click"/>

                <StackPanel>
                    <Button x:Name="buttonMain" Content="🏠 Dashboard" Style="{StaticResource NavButton}" Click="buttonMain_Click"/>
                    <Button x:Name="buttonParts" Content="📦 Magazyn" Style="{StaticResource NavButton}" Click="buttonParts_Click"/>
                    <Button x:Name="buttonRequests" Content="🎟 Zgłoszenia" Style="{StaticResource NavButton}" Click="buttonRequests_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#BDC3C7" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock x:Name="DataLabel" FontSize="13" Margin="0,0,15,0"/>
                    <TextBlock x:Name="TimeLabel" FontSize="13" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <TabControl x:Name="stackedWidget" Grid.Row="1" Margin="15" BorderThickness="0" Background="Transparent">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </TabControl.Resources>

                <!-- Dashboard -->
                <TabItem>
                    <ScrollViewer>
                        <StackPanel>
                            <TextBlock x:Name="WelcomeLabel" Text="Witaj!" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="350"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="Twój profil" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                                        <TextBlock x:Name="FullNameLabel" Margin="0,3"/>
                                        <TextBlock x:Name="RoleLabel" Margin="0,3"/>
                                        <TextBlock x:Name="PhoneLabel" Margin="0,3"/>
                                        <TextBlock x:Name="EmailLabel" Margin="0,3"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="15" Margin="10,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Magazyn" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                                        <TextBlock x:Name="totalPartsLabel" Margin="0,3"/>
                                        <TextBlock x:Name="lowStockLabel" Margin="0,3"/>
                                        <TextBlock x:Name="newRequestsLabel" Margin="0,3"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Magazyn -->
                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Magazyn części" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="🔍 Szukaj:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="partsSearchInput" Width="250" Padding="5" TextChanged="partsSearchInput_TextChanged"/>
                            <Button Content="🔄 Odśwież" Style="{StaticResource GreyButton}" Margin="10,0,5,0" Click="refreshParts_Click"/>
                            <Button Content="➕ Dodaj nową część" Style="{StaticResource SuccessButton}" Margin="5,0" Click="addNewPart_Click"/>
                            <Button Content="📥 Odbiór dostawy" Style="{StaticResource PrimaryButton}" Margin="5,0" Click="receiveDelivery_Click"/>
                        </StackPanel>
                        <DataGrid x:Name="tableParts" Grid.Row="2" Style="{StaticResource DefaultDataGrid}" Background="White">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Cena (zł)" Binding="{Binding Price}" Width="120"/>
                                <DataGridTextColumn Header="Ilość na stanie" Binding="{Binding Quantity}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- Zgłoszenia -->
                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Zgłoszenia mechaników" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Status:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="filterRequestStatus" Width="180" Padding="5" SelectionChanged="filterRequestStatus_SelectionChanged">
                                <ComboBoxItem Content="Wszystkie" IsSelected="True"/>
                                <ComboBoxItem Content="Brak odpowiedzi"/>
                                <ComboBoxItem Content="Zamówiona"/>
                                <ComboBoxItem Content="Gotowa do odbioru"/>
                            </ComboBox>
                            <Button Content="🔄 Odśwież" Style="{StaticResource GreyButton}" Margin="10,0,5,0" Click="refreshRequests_Click"/>
                            <Button Content="↻ Zmień status" Style="{StaticResource WarningButton}" Margin="5,0" Click="changeRequestStatus_Click"/>
                        </StackPanel>
                        <DataGrid x:Name="tableRequests" Grid.Row="2" Style="{StaticResource DefaultDataGrid}" Background="White">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                                <DataGridTextColumn Header="Mechanik" Binding="{Binding MechanicName}" Width="*"/>
                                <DataGridTextColumn Header="Część" Binding="{Binding PartName}" Width="*"/>
                                <DataGridTextColumn Header="Ilość" Binding="{Binding Quantity}" Width="80"/>
                                <DataGridTextColumn Header="Typ" Binding="{Binding Type}" Width="160"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="160"/>
                                <DataGridTextColumn Header="Data zgłoszenia" Binding="{Binding CreatedStr}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
