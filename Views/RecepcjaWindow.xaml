<Window x:Class="CarWorkshopWPF.Views.RecepcjaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panel Recepcji - Warsztat Samochodowy"
        Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#ECF0F1">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#5B2C6F">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Background="#4A235A" Margin="0">
                    <TextBlock Text="🪪 Recepcja" Foreground="White" FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,15,0,0"/>
                    <TextBlock x:Name="labelUser" Text="👤 -" Foreground="#BDC3C7" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,5,0,15"/>
                </StackPanel>

                <Button x:Name="buttonLogout" DockPanel.Dock="Bottom"
                        Content="🚪 Wyloguj" Style="{StaticResource NavButton}" Background="#C0392B"
                        Click="buttonLogout_Click"/>
                <Button x:Name="editProfileButton" DockPanel.Dock="Bottom"
                        Content="✏ Edytuj profil" Style="{StaticResource NavButton}" Background="#4A235A"
                        Click="editProfileButton_Click"/>

                <StackPanel>
                    <Button x:Name="buttonMain" Content="🏠 Dashboard" Style="{StaticResource NavButton}" Click="buttonMain_Click"/>
                    <Button x:Name="buttonReadyCars" Content="✅ Auta do oddania" Style="{StaticResource NavButton}" Click="buttonReadyCars_Click"/>
                    <Button x:Name="buttonNewOrder" Content="➕ Nowe zlecenie" Style="{StaticResource NavButton}" Click="buttonNewOrder_Click"/>
                    <Button x:Name="buttonOrders" Content="📋 Zlecenia" Style="{StaticResource NavButton}" Click="buttonOrders_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#BDC3C7" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock x:Name="DataLabel" FontSize="13" Margin="0,0,15,0"/>
                    <TextBlock x:Name="TimeLabel" FontSize="13" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <TabControl x:Name="stackedWidget" Grid.Row="1" Margin="15" BorderThickness="0" Background="Transparent">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </TabControl.Resources>

                <!-- Dashboard -->
                <TabItem>
                    <ScrollViewer>
                        <StackPanel>
                            <TextBlock x:Name="WelcomeLabel" Text="Witaj!" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="350"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="Twój profil" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                                        <TextBlock x:Name="FullNameLabel" Margin="0,3"/>
                                        <TextBlock x:Name="RoleLabel" Margin="0,3"/>
                                        <TextBlock x:Name="PhoneLabel" Margin="0,3"/>
                                        <TextBlock x:Name="EmailLabel" Margin="0,3"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="15" Margin="10,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Stan zleceń" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                                        <TextBlock x:Name="totalOrdersLabel" Margin="0,3"/>
                                        <TextBlock x:Name="notStartedLabel" Margin="0,3"/>
                                        <TextBlock x:Name="inProgressLabel" Margin="0,3"/>
                                        <TextBlock x:Name="readyLabel" Margin="0,3"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Auta do oddania -->
                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Auta gotowe do odbioru" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="🔄 Odśwież" Style="{StaticResource GreyButton}" Margin="0,0,5,0" Click="refreshReadyCars_Click"/>
                            <Button Content="📋 Pokaż podsumowanie" Style="{StaticResource PrimaryButton}" Margin="5,0" Click="showReadySummary_Click"/>
                            <Button Content="✅ Oznacz jako odebrane" Style="{StaticResource SuccessButton}" Margin="5,0" Click="markPickedUp_Click"/>
                        </StackPanel>
                        <DataGrid x:Name="tableReadyCars" Grid.Row="2" Style="{StaticResource DefaultDataGrid}" Background="White">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Klient" Binding="{Binding Client}" Width="*"/>
                                <DataGridTextColumn Header="Marka" Binding="{Binding Make}" Width="*"/>
                                <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="*"/>
                                <DataGridTextColumn Header="Rejestracja" Binding="{Binding Plate}" Width="120"/>
                                <DataGridTextColumn Header="Mechanik" Binding="{Binding Mechanic}" Width="*"/>
                                <DataGridTextColumn Header="Suma (zł)" Binding="{Binding Total}" Width="100"/>
                                <DataGridTextColumn Header="Zakończono" Binding="{Binding CompletedStr}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- Nowe zlecenie -->
                <TabItem>
                    <ScrollViewer>
                        <StackPanel>
                            <TextBlock Text="Nowe zlecenie naprawy" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                            <Border Background="White" CornerRadius="8" Padding="15">
                                <StackPanel>
                                    <TextBlock Text="Klient" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                                    <UniformGrid Columns="2" Rows="2">
                                        <StackPanel Margin="0,3,8,3">
                                            <TextBlock Text="Imię" FontSize="11"/>
                                            <TextBox x:Name="inputFirstName" Padding="5"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,3,0,3">
                                            <TextBlock Text="Nazwisko" FontSize="11"/>
                                            <TextBox x:Name="inputLastName" Padding="5"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,3,8,3">
                                            <TextBlock Text="Telefon" FontSize="11"/>
                                            <TextBox x:Name="inputClientPhone" Padding="5"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,3,0,3">
                                            <TextBlock Text="Email" FontSize="11"/>
                                            <TextBox x:Name="inputClientEmail" Padding="5"/>
                                        </StackPanel>
                                    </UniformGrid>

                                    <TextBlock Text="Pojazd" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" Margin="0,15,0,8"/>
                                    <UniformGrid Columns="3" Rows="2">
                                        <StackPanel Margin="0,3,8,3">
                                            <TextBlock Text="Marka" FontSize="11"/>
                                            <TextBox x:Name="inputMake" Padding="5"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,3,8,3">
                                            <TextBlock Text="Model" FontSize="11"/>
                                            <TextBox x:Name="inputModel" Padding="5"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,3,0,3">
                                            <TextBlock Text="Rok" FontSize="11"/>
                                            <TextBox x:Name="inputYear" Padding="5"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,3,8,3">
                                            <TextBlock Text="Rejestracja" FontSize="11"/>
                                            <TextBox x:Name="inputPlate" Padding="5"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,3,8,3">
                                            <TextBlock Text="VIN" FontSize="11"/>
                                            <TextBox x:Name="inputVin" Padding="5"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,3,0,3">
                                            <TextBlock Text="Mechanik" FontSize="11"/>
                                            <ComboBox x:Name="comboMechanic" Padding="5"/>
                                        </StackPanel>
                                    </UniformGrid>

                                    <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                                        <Button x:Name="btnSubmitOrder" Content="✓ Dalej (dodaj zadania)"
                                                Style="{StaticResource SuccessButton}" Width="220" Click="btnSubmitOrder_Click"/>
                                        <Button x:Name="btnClearForm" Content="🧹 Wyczyść"
                                                Style="{StaticResource GreyButton}" Width="120" Margin="10,0,0,0" Click="btnClearForm_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Lista zleceń -->
                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Lista zleceń" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Status:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="ordersStatusFilter" Width="180" Padding="5" SelectionChanged="ordersStatusFilter_SelectionChanged">
                                <ComboBoxItem Content="Wszystkie" IsSelected="True"/>
                                <ComboBoxItem Content="Nierozpoczęte"/>
                                <ComboBoxItem Content="W trakcie"/>
                                <ComboBoxItem Content="Czeka na części"/>
                                <ComboBoxItem Content="Gotowe do odbioru"/>
                                <ComboBoxItem Content="Odebrane"/>
                            </ComboBox>
                            <Button Content="🔄 Odśwież" Style="{StaticResource GreyButton}" Margin="10,0,5,0" Click="refreshOrders_Click"/>
                            <Button Content="📋 Podsumowanie" Style="{StaticResource PrimaryButton}" Margin="5,0" Click="showOrderSummary_Click"/>
                            <Button Content="🗑 Usuń" Style="{StaticResource DangerButton}" Margin="5,0" Click="deleteOrder_Click"/>
                        </StackPanel>
                        <DataGrid x:Name="tableOrders" Grid.Row="2" Style="{StaticResource DefaultDataGrid}" Background="White">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Klient" Binding="{Binding Client}" Width="*"/>
                                <DataGridTextColumn Header="Pojazd" Binding="{Binding Vehicle}" Width="*"/>
                                <DataGridTextColumn Header="Mechanik" Binding="{Binding Mechanic}" Width="*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="140"/>
                                <DataGridTextColumn Header="Zadania" Binding="{Binding Tasks}" Width="80"/>
                                <DataGridTextColumn Header="Suma (zł)" Binding="{Binding Total}" Width="100"/>
                                <DataGridTextColumn Header="Utworzono" Binding="{Binding CreatedStr}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
