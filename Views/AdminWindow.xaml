<Window x:Class="CarWorkshopWPF.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="Panel Admina - Warsztat Samochodowy"
        Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#ECF0F1">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#2C3E50">
            <DockPanel>
                <!-- Header sidebar -->
                <StackPanel DockPanel.Dock="Top" Background="#1B2631" Margin="0">
                    <TextBlock Text="🔧 Warsztat" Foreground="White" FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,15,0,0"/>
                    <TextBlock x:Name="labelUser" Text="👤 -" Foreground="#BDC3C7" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,5,0,15"/>
                </StackPanel>

                <!-- Logout na dole -->
                <Button x:Name="buttonLogout" DockPanel.Dock="Bottom"
                        Content="🚪 Wyloguj"
                        Style="{StaticResource NavButton}"
                        Background="#C0392B"
                        Click="buttonLogout_Click"/>

                <Button x:Name="editProfileButton" DockPanel.Dock="Bottom"
                        Content="✏ Edytuj profil"
                        Style="{StaticResource NavButton}"
                        Background="#34495E"
                        Click="editProfileButton_Click"/>

                <!-- Główne menu -->
                <StackPanel>
                    <Button x:Name="buttonMain" Content="🏠 Dashboard" Style="{StaticResource NavButton}" Click="buttonMain_Click"/>
                    <Button x:Name="buttonUsers" Content="👥 Pracownicy" Style="{StaticResource NavButton}" Click="buttonUsers_Click"/>
                    <Button x:Name="buttonClients" Content="🧍 Klienci" Style="{StaticResource NavButton}" Click="buttonClients_Click"/>
                    <Button x:Name="buttonRepairs" Content="🔧 Naprawy" Style="{StaticResource NavButton}" Click="buttonRepairs_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Główna treść -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar z datą i godziną -->
            <Border Grid.Row="0" Background="White" BorderBrush="#BDC3C7" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock x:Name="DataLabel" FontSize="13" Margin="0,0,15,0"/>
                    <TextBlock x:Name="TimeLabel" FontSize="13" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- StackedWidget jako TabControl -->
            <TabControl x:Name="stackedWidget" Grid.Row="1" Margin="15"
                        BorderThickness="0" Background="Transparent">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </TabControl.Resources>

                <!-- Strona 0: Dashboard -->
                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock x:Name="WelcomeLabel" Text="Witaj!" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>

                            <!-- Profil + statystyki -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="350"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="Twój profil" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                                        <TextBlock x:Name="FullNameLabel" Margin="0,3"/>
                                        <TextBlock x:Name="RoleLabel" Margin="0,3"/>
                                        <TextBlock x:Name="PhoneLabel" Margin="0,3"/>
                                        <TextBlock x:Name="EmailLabel" Margin="0,3"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="15" Margin="10,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Status warsztatu" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                                        <TextBlock x:Name="notStartedLabel" Margin="0,3"/>
                                        <TextBlock x:Name="inProgressLabel" Margin="0,3"/>
                                        <TextBlock x:Name="waitingPartsLabel" Margin="0,3"/>
                                        <TextBlock x:Name="completedTodayLabel" Margin="0,3"/>
                                        <TextBlock x:Name="pickedUpLabel" Margin="0,3"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Statystyki finansowe -->
                            <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="💰 Finanse - dzisiaj" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="incomeLabel" Margin="0,3"/>
                                    <TextBlock x:Name="partsCostLabel" Margin="0,3"/>
                                    <TextBlock x:Name="netProfitLabel" Margin="0,3" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <!-- Wykresy -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="10" Margin="0,0,5,0" Height="300">
                                    <StackPanel>
                                        <TextBlock Text="Aktywność dzisiaj" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                        <lvc:CartesianChart x:Name="ChartActivity" Height="240"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="10" Margin="5,0" Height="300">
                                    <StackPanel>
                                        <TextBlock Text="Auta na warsztacie" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                        <lvc:PieChart x:Name="ChartCarsInWorkshop" Height="240"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="10" Margin="5,0,0,0" Height="300">
                                    <StackPanel>
                                        <TextBlock Text="Finanse dzisiaj" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                        <lvc:CartesianChart x:Name="ChartFinance" Height="240"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Strona 1: Pracownicy -->
                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Zarządzanie pracownikami" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Dodaj nowego pracownika" FontWeight="Bold" Margin="0,0,0,10"/>
                                <UniformGrid Columns="3" Rows="2">
                                    <StackPanel Margin="0,3,10,3">
                                        <TextBlock Text="Login" FontSize="11"/>
                                        <TextBox x:Name="inputWorkerLogin" Padding="5"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,3,10,3">
                                        <TextBlock Text="Hasło" FontSize="11"/>
                                        <TextBox x:Name="inputWorkerPass" Padding="5"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,3,0,3">
                                        <TextBlock Text="Rola" FontSize="11"/>
                                        <ComboBox x:Name="inputWorkerRole" Padding="5">
                                            <ComboBoxItem Content="mechanic" IsSelected="True"/>
                                            <ComboBoxItem Content="recepcja"/>
                                            <ComboBoxItem Content="magazynier"/>
                                            <ComboBoxItem Content="admin"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Margin="0,3,10,3">
                                        <TextBlock Text="Imię" FontSize="11"/>
                                        <TextBox x:Name="inputWorkerName" Padding="5"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,3,10,3">
                                        <TextBlock Text="Nazwisko" FontSize="11"/>
                                        <TextBox x:Name="inputWorkerLName" Padding="5"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,3,0,3">
                                        <TextBlock Text="Telefon / Email" FontSize="11"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="inputWorkerNumber" Padding="5" Grid.Column="0" Margin="0,0,3,0"/>
                                            <TextBox x:Name="inputWorkerEmail" Padding="5" Grid.Column="1" Margin="3,0,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                </UniformGrid>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button x:Name="btnAddWorker" Content="➕ Dodaj pracownika" Style="{StaticResource SuccessButton}" Click="btnAddWorker_Click" Margin="0,0,5,0"/>
                                    <Button x:Name="btnDeleteWorker" Content="🗑 Usuń zaznaczonego" Style="{StaticResource DangerButton}" Click="btnDeleteWorker_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <DataGrid x:Name="tableWorkers" Grid.Row="2" Style="{StaticResource DefaultDataGrid}" Background="White">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                                <DataGridTextColumn Header="Login" Binding="{Binding Login}" Width="*"/>
                                <DataGridTextColumn Header="Rola" Binding="{Binding Role}" Width="*"/>
                                <DataGridTextColumn Header="Imię" Binding="{Binding FirstName}" Width="*"/>
                                <DataGridTextColumn Header="Nazwisko" Binding="{Binding LastName}" Width="*"/>
                                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                                <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- Strona 2: Klienci -->
                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Klienci" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                        <Button x:Name="btnRefreshClients" Grid.Row="1" Content="🔄 Odśwież"
                                Style="{StaticResource GreyButton}" Width="120" HorizontalAlignment="Left" Margin="0,0,0,10"
                                Click="btnRefreshClients_Click"/>

                        <DataGrid x:Name="tableClients" Grid.Row="2" Style="{StaticResource DefaultDataGrid}" Background="White">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                <DataGridTextColumn Header="Imię" Binding="{Binding FirstName}" Width="*"/>
                                <DataGridTextColumn Header="Nazwisko" Binding="{Binding LastName}" Width="*"/>
                                <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="*"/>
                                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- Strona 3: Naprawy -->
                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Wszystkie naprawy" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                        <Button x:Name="btnRefreshRepairs" Grid.Row="1" Content="🔄 Odśwież"
                                Style="{StaticResource GreyButton}" Width="120" HorizontalAlignment="Left" Margin="0,0,0,10"
                                Click="btnRefreshRepairs_Click"/>

                        <DataGrid x:Name="tableRepairs" Grid.Row="2" Style="{StaticResource DefaultDataGrid}" Background="White">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                                <DataGridTextColumn Header="Pojazd" Binding="{Binding VehicleStr}" Width="*"/>
                                <DataGridTextColumn Header="Klient" Binding="{Binding ClientStr}" Width="*"/>
                                <DataGridTextColumn Header="Mechanik" Binding="{Binding MechanicStr}" Width="*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="140"/>
                                <DataGridTextColumn Header="Data zgłoszenia" Binding="{Binding CreatedStr}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
