<Window x:Class="CarWorkshopWPF.Views.InputNumberDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="220" Width="380"
        WindowStartupLocation="CenterOwner"
        Background="White"
        ResizeMode="NoResize">
    <StackPanel Margin="20">
        <TextBlock x:Name="PromptText" FontSize="13" Margin="0,0,0,10" TextWrapping="Wrap"/>
        <TextBox x:Name="ValueTextBox" Padding="6" FontSize="14"/>
        <StackPanel Orientation="Horizontal" Margin="0,15,0,0" HorizontalAlignment="Right">
            <Button Content="Anuluj" Style="{StaticResource GreyButton}" Width="100" Click="CancelButton_Click" Margin="0,0,5,0"/>
            <Button Content="OK" Style="{StaticResource SuccessButton}" Width="100" Click="OkButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
